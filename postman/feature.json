              "raw": "{\n  \"title\": \"Open comments event\",\n  \"annotation\": \"Open event annotation long enough for validation.\",\n  \"description\": \"Open event description long enough for validation and comment feature setup.\",\n  \"eventDate\": \"{{futureEventDate1}}\",\n  \"paid\": false,\n  \"requestModeration\": false,\n  \"participantLimit\": 0,\n  \"location\": {\n    \"lat\": 55.751244,\n    \"lon\": 37.618423\n  },\n  \"category\": {{categoryId}}\n}",
